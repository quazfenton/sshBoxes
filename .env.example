# sshBox Environment Configuration
# Copy this file to .env and customize for your environment

# ===========================================
# Application Settings
# ===========================================
SSHBOX_APP_NAME=sshBox
SSHBOX_APP_VERSION=2.0.0
SSHBOX_DEBUG=false
SSHBOX_ENVIRONMENT=development

# Gateway Settings
SSHBOX_GATEWAY_HOST=0.0.0.0
SSHBOX_GATEWAY_PORT=8080
SSHBOX_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8083

# ===========================================
# Security Settings (CRITICAL - Change in Production!)
# ===========================================
# Generate a secure secret: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SSHBOX_SECURITY_GATEWAY_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
SSHBOX_SECURITY_SECRET_MIN_LENGTH=32
SSHBOX_SECURITY_TOKEN_MAX_AGE=300
SSHBOX_SECURITY_ALLOWED_PROFILES=dev,debug,secure-shell,privileged,interview

# Rate Limiting
SSHBOX_SECURITY_RATE_LIMIT_REQUEST=5/minute
SSHBOX_SECURITY_RATE_LIMIT_SESSIONS=10/minute
SSHBOX_SECURITY_RATE_LIMIT_DESTROY=20/hour
SSHBOX_SECURITY_RATE_LIMIT_ENABLED=true

# SSH Key Settings
SSHBOX_SECURITY_SSH_MIN_RSA_BITS=2048
SSHBOX_SECURITY_ALLOWED_KEY_TYPES=ssh-rsa,ssh-ed25519,ecdsa-sha2-nistp256,ecdsa-sha2-nistp384,ecdsa-sha2-nistp521

# ===========================================
# Database Settings
# ===========================================
SSHBOX_DB_DB_TYPE=sqlite
SSHBOX_DB_SQLITE_PATH=/var/lib/sshbox/sessions.db

# PostgreSQL Settings (if using PostgreSQL)
# SSHBOX_DB_DB_TYPE=postgresql
SSHBOX_DB_POSTGRES_HOST=localhost
SSHBOX_DB_POSTGRES_PORT=5432
SSHBOX_DB_POSTGRES_DB=sshbox
SSHBOX_DB_POSTGRES_USER=sshbox_user
SSHBOX_DB_POSTGRES_PASS=change-this-password
SSHBOX_DB_POOL_SIZE=10
SSHBOX_DB_POOL_TIMEOUT=30

# ===========================================
# Storage Settings
# ===========================================
SSHBOX_STORAGE_RECORDINGS_DIR=/var/lib/sshbox/recordings
SSHBOX_STORAGE_RECORDINGS_RETENTION_DAYS=7
SSHBOX_STORAGE_ENABLE_RECORDING=true
SSHBOX_STORAGE_MAX_RECORDING_SIZE_MB=100

SSHBOX_STORAGE_LOGS_DIR=/var/log/sshbox
SSHBOX_STORAGE_LOG_LEVEL=INFO
SSHBOX_STORAGE_LOG_FORMAT=json
SSHBOX_STORAGE_LOG_MAX_BYTES=10485760
SSHBOX_STORAGE_LOG_BACKUP_COUNT=5

SSHBOX_STORAGE_METRICS_FILE=/var/lib/sshbox/metrics.json

# ===========================================
# Provisioner Settings
# ===========================================
SSHBOX_PROVISIONER_PROVISIONER_TYPE=container
SSHBOX_PROVISIONER_PROVISIONER_PATH=./scripts/box-provision.sh
SSHBOX_PROVISIONER_CONTAINER_RUNTIME=docker
SSHBOX_PROVISIONER_CONTAINER_IMAGE=ephemeral-box:latest
SSHBOX_PROVISIONER_ENABLE_RECORDING=true

# Firecracker Settings (if using Firecracker)
# SSHBOX_PROVISIONER_PROVISIONER_TYPE=firecracker
SSHBOX_PROVISIONER_FIRECRACKER_SOCKET_DIR=/var/run/firecracker
SSHBOX_PROVISIONER_KERNEL_IMAGE=/var/lib/firecracker/kernel/vmlinux
SSHBOX_PROVISIONER_ROOTFS_IMAGE=/var/lib/firecracker/rootfs/rootfs.ext4
SSHBOX_PROVISIONER_VM_MEM_SIZE_MIB=2048
SSHBOX_PROVISIONER_VM_VCPU_COUNT=2

# TTL Settings
SSHBOX_PROVISIONER_DEFAULT_TTL=1800
SSHBOX_PROVISIONER_MAX_TTL=7200
SSHBOX_PROVISIONER_MIN_TTL=60

# ===========================================
# Redis Settings (optional, for distributed deployments)
# ===========================================
SSHBOX_REDIS_HOST=localhost
SSHBOX_REDIS_PORT=6379
SSHBOX_REDIS_DB=0
SSHBOX_REDIS_PASSWORD=
SSHBOX_REDIS_URL=redis://localhost:6379/0

# ===========================================
# Web Terminal Settings
# ===========================================
SSHBOX_WEB_PORT=3000
SSHBOX_WEB_GATEWAY_URL=http://localhost:8080
SSHBOX_WEB_CORS_ENABLED=true
SSHBOX_WEB_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ===========================================
# Interview Mode Settings
# ===========================================
SSHBOX_INTERVIEW_API_PORT=8083
SSHBOX_INTERVIEW_STORAGE=/var/lib/sshbox/interviews
SSHBOX_INTERVIEW_GATEWAY_URL=http://localhost:8080
SSHBOX_INTERVIEW_DEFAULT_TTL=3600
SSHBOX_INTERVIEW_MAX_TTL=7200
SSHBOX_INTERVIEW_DEFAULT_PROBLEM=two_sum
SSHBOX_INTERVIEW_DEFAULT_LANGUAGE=python
SSHBOX_INTERVIEW_RECORDING_ENABLED=true

# ===========================================
# Policy Engine Settings (OPA)
# ===========================================
SSHBOX_POLICY_OPA_URL=http://localhost:8181
SSHBOX_POLICY_PACKAGE=sshbox/authz
SSHBOX_POLICY_FALLBACK_ENABLED=true
SSHBOX_POLICY_TIMEOUT_SECONDS=5
SSHBOX_POLICY_LOCAL_STORAGE=/etc/sshbox/policies

# ===========================================
# Quota Manager Settings
# ===========================================
SSHBOX_QUOTA_DB_PATH=/var/lib/sshbox/quotas.db
SSHBOX_QUOTA_REDIS_ENABLED=true
SSHBOX_QUOTA_REDIS_CACHE_TTL=60
SSHBOX_QUOTA_DEFAULT_MAX_SESSIONS=10
SSHBOX_QUOTA_DEFAULT_MAX_CONCURRENT=5
SSHBOX_QUOTA_DEFAULT_MAX_DAILY=50
SSHBOX_QUOTA_DEFAULT_MAX_TTL=7200

# ===========================================
# Circuit Breaker Settings
# ===========================================
SSHBOX_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
SSHBOX_CIRCUIT_BREAKER_SUCCESS_THRESHOLD=3
SSHBOX_CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30

# ===========================================
# Monitoring Settings
# ===========================================
SSHBOX_MONITORING_PROMETHEUS_ENABLED=true
SSHBOX_MONITORING_PROMETHEUS_PORT=9090
SSHBOX_MONITORING_GRAFANA_ENABLED=true
SSHBOX_MONITORING_GRAFANA_PORT=3001
SSHBOX_MONITORING_HEALTH_CHECK_INTERVAL=30
SSHBOX_MONITORING_METRICS_ENDPOINT=/metrics

# ===========================================
# Docker Compose Settings
# ===========================================
SSHBOX_DOCKER_COMPOSE_FILE=docker-compose.yml
SSHBOX_DOCKER_NETWORK=sshbox-net
SSHBOX_DOCKER_VOLUME_POSTGRES=/var/lib/sshbox/postgres
SSHBOX_DOCKER_VOLUME_REDIS=/var/lib/sshbox/redis
SSHBOX_DOCKER_VOLUME_RECORDINGS=/var/lib/sshbox/recordings

# ===========================================
# Production Settings
# ===========================================
# SSHBOX_ENVIRONMENT=production
# SSHBOX_DEBUG=false
# SSHBOX_LOG_LEVEL=WARNING
# SSHBOX_SECURITY_RATE_LIMIT_ENABLED=true
# SSHBOX_MONITORING_PROMETHEUS_ENABLED=true
# SSHBOX_MONITORING_GRAFANA_ENABLED=true

# ===========================================
# SSL/TLS Settings (Production)
# ===========================================
# SSHBOX_SSL_ENABLED=true
# SSHBOX_SSL_CERT_PATH=/etc/ssl/certs/sshbox.crt
# SSHBOX_SSL_KEY_PATH=/etc/ssl/private/sshbox.key

# ===========================================
# SSO Settings (Enterprise)
# ===========================================
# SSHBOX_SSO_ENABLED=false
# SSHBOX_SSO_PROVIDER=okta
# SSHBOX_SSO_CLIENT_ID=
# SSHBOX_SSO_CLIENT_SECRET=
# SSHBOX_SSO_REDIRECT_URI=

# ===========================================
# Email Settings (for interview invites)
# ===========================================
# SSHBOX_EMAIL_ENABLED=false
# SSHBOX_EMAIL_SMTP_HOST=smtp.gmail.com
# SSHBOX_EMAIL_SMTP_PORT=587
# SSHBOX_EMAIL_SMTP_USER=
# SSHBOX_EMAIL_SMTP_PASSWORD=
# SSHBOX_EMAIL_FROM_ADDRESS=noreply@sshbox.io
